# ═══════════════════════════════════════════════════════════════
# 🧀 CheeseDog Polymarket 智慧交易輔助系統 - 環境變數設定
# ═══════════════════════════════════════════════════════════════
# 請複製此檔案為 .env 並填入您的實際值
# cp .env.example .env

# ── Binance API ──────────────────────────────────────────────
# 公共數據無需 API Key，帳戶操作需要
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── Polymarket ───────────────────────────────────────────────
# Polymarket 系列設定
POLYMARKET_SERIES_SLUG=btc-up-or-down-15m
POLYMARKET_AUTO_SELECT_LATEST=true

# ── Polygon / Chainlink ─────────────────────────────────────
# 主要 RPC 節點（填入你的私有節點，含 API key）
# 免費公共節點：https://polygon-rpc.com
# dRPC 私有節點：https://drpc.org
POLYGON_RPC_URL=https://polygon-rpc.com
# 備用節點（選填，填入後會依序嘗試加入輪換清單）
POLYGON_RPC_1_URL=
POLYGON_RPC_2_URL=
POLYGON_RPC_3_URL=
POLYGON_RPC_4_URL=
CHAINLINK_BTC_USD_AGGREGATOR=0xc907E116054Ad103354f2D350FD2514433D57F6f

# ── 實盤交易設定（Step 16: Polymarket CLOB API）──────────────
# ⚠️ 警告：請妥善保管私鑰，切勿外洩！
#
# WALLET_PRIVATE_KEY: 你的 Polygon 錢包私鑰 (用於簽署訂單)
# PM_FUNDER_ADDRESS: (選填) 若使用 Proxy Wallet，填入持有資金的地址
# PM_SIGNATURE_TYPE: (選填) 簽名類型
#   0 = EOA/MetaMask (預設)
#   1 = Email/Magic Wallet
#   2 = Browser Proxy Wallet
# PM_LIVE_ENABLED: 是否啟用實盤交易 (安全閥：預設 false)
# PM_BUILDER_API_KEY: Polymarket Order Attribution API Key
# PM_BUILDER_SECRET: Polymarket Order Attribution Secret
# PM_BUILDER_PASSPHRASE: Polymarket Order Attribution Passphrase
# PM_API_IS_VERIFIED: 帳號是否為 Polymarket Verified 層級？
#   - true = Verified 額度 (3000 tx/day)
#   - false = Unverified 額度 (100 tx/day)
#
WALLET_PRIVATE_KEY=
PM_FUNDER_ADDRESS=
PM_SIGNATURE_TYPE=0
PM_LIVE_ENABLED=false
PM_BUILDER_API_KEY=
PM_BUILDER_SECRET=
PM_BUILDER_PASSPHRASE=
PM_API_IS_VERIFIED=false

# ── 系統設定 ─────────────────────────────────────────────────
# 後端伺服器
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8888

# 日誌級別
LOG_LEVEL=INFO

# 模擬交易初始金額 (USDC)
SIM_INITIAL_BALANCE=1000.0

# ── 內建 LLM AI 引擎設定（OpenAI Compatible）──────────────────
# 支援任何 OpenAI Compatible API（OpenAI、NVIDIA NIM、DeepSeek、Groq、本地 Ollama 等）
# 這是最安全的設定方式 — Key 永遠不會離開伺服器，也不會出現在前端
#
# AI_MONITOR_ENABLED: 是否啟動內建 AI 分析引擎（預設停用）
# AI_MONITOR_INTERVAL: 自動分析間隔（秒，預設 900 = 15 分鐘）
# OPENAI_API_KEY: LLM Provider 的 API Key
# OPENAI_BASE_URL: API 基礎 URL（預設 OpenAI，可改為其他 Provider）
# OPENAI_MODEL: 使用的模型名稱
#
# 範例 — 使用 NVIDIA NIM：
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_API_KEY=nvapi-xxxxxxxxxxxx
#   OPENAI_MODEL=meta/llama-3.1-70b-instruct
#
# 範例 — 使用 DeepSeek：
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_API_KEY=sk-xxxxxxxxxxxx
#   OPENAI_MODEL=deepseek-chat
#
# 範例 — 使用本地 Ollama：
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
#   OPENAI_MODEL=llama3
#
AI_MONITOR_ENABLED=false
AI_MONITOR_INTERVAL=900
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo

# ── Telegram 控制與權限管理 (第四階段) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

AI_NAVIGATOR=internal
AUTHORIZATION_MODE=hitl

# ── 深度防禦：X-API-Key 設定 ───────────────────────────────
# 為敏感 API 端點加入第二層存取控制（防 Lateral Movement）
# 設定後，所有狀態變更 API 都需要帶 X-API-Key Header
# 留空 = 停用驗證（開發模式）；建議上線時務必設定一組強密碼
# 同時需在 frontend-v2/.env 設定相同的 VITE_API_KEY
CHEESEDOG_API_KEY=
